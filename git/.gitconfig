[user]
    name = ${GIT_AUTHOR_NAME:-Your Name}
    email = ${GIT_AUTHOR_EMAIL:-you@example.com}

[core]
    editor = vim
    autocrlf = input
    safecrlf = warn

[pull]
    rebase = true

[push]
    default = simple

[init]
    defaultBranch = main

[alias]
    st = status
    co = checkout
    br = branch
    ci = commit
    lg = log --oneline --graph --decorate
    last = log -1 HEAD
    unstage = reset HEAD --
    amend = commit --amend --no-edit

[fetch]
    prune = true

[rebase]
    autoStash = true

[color]
    ui = auto

[credential]
    helper = osxkeychain  # macOS
#   helper = libsecret   # Linux (if available)
