# ==============================================================================
# 1PASSWORD ENVIRONMENT MAP
# This file contains ONLY references (op://). No real secrets are stored here.
# ==============================================================================

if command -v op &> /dev/null; then
    # GitHub
    GH_TOKEN=$(op read "op://dotfiles/GitHub/admintoken")
    GITHUB_TOKEN=$(op read "op://dotfiles/GitHub/admintoken")

    # Claude / OpenRouter / Anthropic
    OPENROUTER_API_KEY=$(op read "op://dotfiles/OpenRouter/generaltoken")
    ANTHROPIC_BASE_URL=https://openrouter.ai/api
    ANTHROPIC_AUTH_TOKEN=$(op read "op://dotfiles/OpenRouter/generaltoken")
    ANTHROPIC_API_KEY=
    ANTHROPIC_MODEL=moonshotai/kimi-k2.6

    # Gemini
    GEMINI_API_KEY=$(op read "op://dotfiles/Google/gemini-cli-token")
fi